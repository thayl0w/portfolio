---
import { site } from '../data/portfolio';
---

<section id="hero" class="relative flex min-h-screen items-center overflow-hidden bg-surface pt-16">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute -top-40 right-0 h-[500px] w-[500px] rounded-full bg-accent/20 blur-[120px]"></div>
    <div class="absolute -bottom-40 left-0 h-[400px] w-[400px] rounded-full bg-navy-deep/5 blur-[100px]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_0%,#ffffff_70%)]"></div>
  </div>

  <div class="section-container relative z-10 py-20 sm:py-28">
    <div class="max-w-4xl">
      <p class="mb-4 inline-flex items-center gap-2 rounded-full border border-accent/50 bg-accent/20 px-4 py-1.5 text-sm font-medium text-navy-deep animate-fade-in">
        <span class="h-2 w-2 rounded-full bg-accent animate-pulse"></span>
        Available for opportunities
      </p>

      <h1 class="text-4xl font-extrabold leading-tight tracking-tight text-navy sm:text-5xl md:text-6xl lg:text-7xl animate-slide-up">
        {site.name}
      </h1>

      <p class="mt-6 text-lg font-semibold text-navy-deep sm:text-xl md:text-2xl animate-slide-up" style="animation-delay: 0.1s">
        {site.tagline}
      </p>

      <p class="mt-4 flex items-center gap-2 text-base text-gray-600 sm:text-lg animate-slide-up" style="animation-delay: 0.2s">
        <svg class="h-5 w-5 text-accent-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        {site.location}
      </p>

      <div class="mt-10 flex flex-col gap-4 sm:flex-row animate-slide-up" style="animation-delay: 0.3s">
        <a href="#projects" class="btn-primary">
          View My Work
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
          </svg>
        </a>
        <a href={site.resumeUrl} class="btn-secondary" download>
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
          Download Resume
        </a>
      </div>
    </div>
  </div>
</section>