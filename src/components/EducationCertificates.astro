---
import { educationCertificates } from '../data/portfolio';
---

<section id="education-certificates" class="bg-surface-muted py-20 sm:py-28">
  <div class="section-container">
    <h2 class="section-heading">Education & Certificates</h2>
    <p class="section-subheading">
      Academic credentials and professional certifications from Brigham Young University-Idaho.
    </p>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        educationCertificates.map((item) => (
          <button
            type="button"
            class="edu-cert-card card group flex w-full cursor-pointer flex-col p-0 text-left"
            data-pdf={item.pdfUrl}
            data-title={item.title}
            aria-label={`View ${item.title} certificate`}
          >
            <div class="flex items-start gap-4 p-5">
              <div
                class:list={[
                  'flex h-12 w-12 shrink-0 items-center justify-center rounded-xl ring-1 transition-all duration-300 group-hover:scale-105',
                  item.type === 'degree'
                    ? 'bg-accent/30 text-navy-deep ring-accent/40 group-hover:bg-accent/50'
                    : 'bg-navy-deep/10 text-navy-deep ring-navy-deep/15 group-hover:bg-navy-deep/15',
                ]}
              >
                {item.type === 'degree' ? (
                  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path d="M12 14l9-5-9-5-9 5 9 5z" />
                    <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824 2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824 2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" />
                  </svg>
                ) : (
                  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                  </svg>
                )}
              </div>

              <div class="min-w-0 flex-1">
                <span
                  class:list={[
                    'inline-flex rounded-md px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide',
                    item.type === 'degree'
                      ? 'bg-accent/25 text-navy-deep'
                      : 'bg-navy-deep/10 text-navy-deep',
                  ]}
                >
                  {item.type === 'degree' ? 'Degree' : 'Certificate'}
                </span>
                <h3 class="mt-2 text-base font-bold leading-snug text-navy transition-colors group-hover:text-navy-deep">
                  {item.title}
                </h3>
                <p class="mt-1.5 text-sm text-gray-500">{item.institution}</p>
              </div>
            </div>

            <div class="flex items-center justify-between border-t border-gray-200 px-5 py-3">
              <span class="text-sm font-medium text-gray-600">{item.date}</span>
              <span class="inline-flex items-center gap-1 text-xs font-medium text-gray-400 transition-colors duration-300 group-hover:text-navy-deep">
                View PDF
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                </svg>
              </span>
            </div>
          </button>
        ))
      }
    </div>
  </div>
</section>

<div
  id="edu-cert-modal"
  class="fixed inset-0 z-[100] hidden items-center justify-center p-4 sm:p-6"
  role="dialog"
  aria-modal="true"
  aria-labelledby="edu-cert-modal-title"
  aria-hidden="true"
>
  <div id="edu-cert-backdrop" class="absolute inset-0 bg-navy/60 backdrop-blur-sm"></div>

  <div class="relative flex max-h-[92vh] w-full max-w-4xl flex-col overflow-hidden rounded-2xl border border-gray-200 bg-surface shadow-2xl shadow-navy/20">
    <div class="flex items-center justify-between gap-4 border-b border-gray-200 px-5 py-4 sm:px-6">
      <h3 id="edu-cert-modal-title" class="truncate pr-4 text-base font-bold text-navy sm:text-lg"></h3>
      <div class="flex shrink-0 items-center gap-2">
        <a
          id="edu-cert-download"
          href="#"
          class="btn-outline hidden text-xs sm:inline-flex"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
          Download
        </a>
        <button
          id="edu-cert-close"
          type="button"
          class="flex h-9 w-9 items-center justify-center rounded-lg border border-gray-300 text-navy transition-colors hover:border-soft-yellow-dark hover:bg-soft-yellow/10"
          aria-label="Close certificate viewer"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <div class="flex-1 overflow-hidden bg-surface-alt">
      <iframe
        id="edu-cert-iframe"
        class="h-[70vh] w-full border-0"
        title="Certificate PDF viewer"
      ></iframe>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('edu-cert-modal');
  const backdrop = document.getElementById('edu-cert-backdrop');
  const closeBtn = document.getElementById('edu-cert-close');
  const iframe = document.getElementById('edu-cert-iframe') as HTMLIFrameElement | null;
  const modalTitle = document.getElementById('edu-cert-modal-title');
  const downloadLink = document.getElementById('edu-cert-download') as HTMLAnchorElement | null;
  const cards = document.querySelectorAll<HTMLButtonElement>('.edu-cert-card');

  let lastFocused: HTMLElement | null = null;

  function openModal(pdfUrl: string, title: string) {
    if (!modal || !iframe || !modalTitle || !downloadLink) return;

    lastFocused = document.activeElement as HTMLElement;
    modalTitle.textContent = title;
    iframe.src = pdfUrl;
    downloadLink.href = pdfUrl;

    modal.classList.remove('hidden');
    modal.classList.add('flex');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    closeBtn?.focus();
  }

  function closeModal() {
    if (!modal || !iframe) return;

    modal.classList.add('hidden');
    modal.classList.remove('flex');
    modal.setAttribute('aria-hidden', 'true');
    iframe.src = '';
    document.body.style.overflow = '';
    lastFocused?.focus();
  }

  cards.forEach((card) => {
    card.addEventListener('click', () => {
      const pdfUrl = card.dataset.pdf;
      const title = card.dataset.title;
      if (pdfUrl && title) openModal(pdfUrl, title);
    });
  });

  closeBtn?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
      closeModal();
    }
  });
</script>