---
import { site, navLinks } from '../data/portfolio';
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 border-b border-gray-200 bg-surface/90 backdrop-blur-xl transition-all duration-300"
>
  <nav class="section-container flex h-16 items-center justify-between">
    <a
      href="#hero"
      class="group flex items-center gap-2 font-bold text-navy transition-colors hover:text-navy-deep"
    >
      <span
        class="flex h-9 w-9 items-center justify-center rounded-lg bg-accent text-sm font-extrabold text-navy ring-1 ring-accent/40 transition-all group-hover:bg-accent-light group-hover:ring-accent"
      >
        {site.shortName}
      </span>
    </a>

    <ul class="hidden items-center gap-8 md:flex">
      {
        navLinks.map((link) => (
          <li>
            <a href={link.href} class="nav-link hover:text-navy-deep">
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <a href={site.resumeUrl} class="btn-primary hidden text-xs sm:text-sm md:inline-flex">
      Download Resume
    </a>

    <button
      id="menu-toggle"
      type="button"
      class="relative z-50 flex h-10 w-10 items-center justify-center rounded-lg border border-gray-300 text-navy md:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="sr-only">Open menu</span>
      <svg id="icon-open" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
      <svg id="icon-close" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-gray-200 bg-surface md:hidden">
    <ul class="section-container flex flex-col gap-1 py-4">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="mobile-nav-link block rounded-lg px-4 py-3 text-base font-medium text-gray-700 transition-colors hover:bg-accent/10 hover:text-navy-deep"
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li class="mt-2 px-4">
        <a href={site.resumeUrl} class="btn-primary w-full">Download Resume</a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');
  const navbar = document.getElementById('navbar');
  const mobileLinks = document.querySelectorAll('.mobile-nav-link');

  let isOpen = false;

  function setMenuOpen(open: boolean) {
    isOpen = open;
    menu?.classList.toggle('hidden', !open);
    iconOpen?.classList.toggle('hidden', open);
    iconClose?.classList.toggle('hidden', !open);
    toggle?.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';
  }

  toggle?.addEventListener('click', () => setMenuOpen(!isOpen));

  mobileLinks.forEach((link) => {
    link.addEventListener('click', () => setMenuOpen(false));
  });

  window.addEventListener('scroll', () => {
    if (!navbar) return;
    navbar.classList.toggle('shadow-md shadow-gray-200/80', window.scrollY > 20);
  });
</script>