---
import { certificates } from '../data/portfolio';
---

<section id="certificates" class="bg-surface py-20 sm:py-28">
  <div class="section-container">
    <h2 class="section-heading">Certificates</h2>
    <p class="section-subheading">
      Professional certifications and completed training programs.
    </p>

    <div class="mt-12 grid grid-cols-2 gap-4 sm:gap-6 lg:grid-cols-4">
      {
        certificates.map((cert) => (
          <article class="card group overflow-hidden p-0">
            <div class="relative aspect-[4/3] overflow-hidden bg-surface-alt">
              <img
                src={cert.image}
                alt={cert.title}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-accent/0 transition-colors duration-300 group-hover:bg-accent/10"></div>
            </div>
            <div class="p-4">
              <h3 class="line-clamp-2 text-sm font-semibold text-navy transition-colors group-hover:text-navy-deep">
                {cert.title}
              </h3>
              <p class="mt-1 text-xs text-gray-500">{cert.issuer}</p>
              <p class="mt-1 text-xs font-medium text-navy-deep">{cert.year}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>