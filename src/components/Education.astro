---
import { education } from '../data/portfolio';
---

<section id="education" class="bg-surface-muted py-20 sm:py-28">
  <div class="section-container">
    <h2 class="section-heading">Education</h2>
    <p class="section-subheading">
      Academic foundation in software development and computer science.
    </p>

    <article class="card mt-12 max-w-3xl group">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div class="flex gap-4">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-accent/30 text-navy-deep ring-1 ring-accent/40 transition-all group-hover:bg-accent/50">
            <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M12 14l9-5-9-5-9 5 9 5z"></path>
              <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824 2.998 12.078 12.078 0 01.665-6.479L12 14z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824 2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"></path>
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-bold text-navy transition-colors group-hover:text-navy-deep">
              {education.school}
            </h3>
            <p class="mt-1 font-medium text-navy-deep">{education.degree}</p>
            <p class="mt-1 text-sm text-gray-500">{education.location}</p>
          </div>
        </div>
        <span class="inline-flex shrink-0 items-center rounded-lg border border-gray-200 bg-surface-muted px-3 py-1 text-sm font-medium text-gray-600">
          {education.period}
        </span>
      </div>

      <ul class="mt-6 space-y-3 border-t border-gray-200 pt-6">
        {
          education.details.map((detail) => (
            <li class="flex gap-3 text-sm leading-relaxed text-gray-700">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
              <span>{detail}</span>
            </li>
          ))
        }
      </ul>
    </article>
  </div>
</section>